{
  "name": "soundlab",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "SoundLab — Mesopotamian tuning philology, binaural demos, acoustics (Iraq journal corpus, UET VII 74, presets).",
  "scripts": {
    "start": "tsx src/index.ts",
    "test": "vitest run",
    "midi:tightening": "tsx src/playTighteningCycle.ts",
    "audio:binaural": "tsx src/exportTighteningBinaural.ts",
    "audio:beat": "tsx src/exportPureBinaural.ts",
    "audio:preset": "tsx src/runPreset.ts",
    "audio:preset:all": "tsx src/runAllPresets.ts",
    "acoustics:demo": "tsx src/runAcousticsDemo.ts",
    "install": "npm install --prefix web",
    "dev": "npm run dev --prefix web",
    "build": "npm run build --prefix web",
    "copy-assets": "npm run copy-assets --prefix web"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "midi-writer-js": "^3.2.1"
  }
}
